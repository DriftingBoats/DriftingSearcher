# 服务器配置
PORT=3001
NODE_ENV=development

# Puppeteer配置
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# 搜索配置
MAX_CONCURRENT_SEARCHES=3
SEARCH_DELAY_MS=1000
MAX_RESULTS_PER_CHANNEL=50

# 可选：夸克网盘 Session Cookie（配置后自动校验分享是否有效，过滤失效链接）
# 获取方式：登录 pan.quark.cn → F12 → Network 面板 → 任意请求 → Request Headers → 复制 Cookie 字段值
# 不填则跳过校验，所有夸克链接均展示（无误报）
QUARK_COOKIE=