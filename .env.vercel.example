# Vercel Environment Variables
# Copy this file to your Vercel dashboard environment variables section

# Telegram Channels Configuration (JSON format)
# Alternative to resource_channel_config.json file
TELEGRAM_CHANNELS=[{"id":"example_channel","name":"示例频道","type":"资源"}]

# 可选：夸克网盘 Session Cookie（配置后自动校验分享是否有效，过滤失效链接）
# 获取方式：登录 pan.quark.cn → F12 → Network 面板 → 任意请求 → Request Headers → 复制 Cookie 字段值
# 不填则跳过校验，所有夸克链接均展示（无误报）
# 有效期约 7-30 天，过期后需重新获取
QUARK_COOKIE=